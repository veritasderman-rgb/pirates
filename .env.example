# Serverless payment config — set these on Vercel (never commit real values).
# See docs/STRIPE_PAYWALL_PLAN.md.

# Stripe secret key (test: sk_test_..., live: sk_live_...)
STRIPE_SECRET_KEY=

# The one-time Price id for the full-game unlock (price_...)
STRIPE_PRICE_ID=

# Webhook signing secret from the Stripe dashboard endpoint (whsec_...)
STRIPE_WEBHOOK_SECRET=

# HMAC key for signing license tokens — a long random string, keep it stable
LICENSE_SIGNING_SECRET=
